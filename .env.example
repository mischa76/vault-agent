# Copy to .env and fill in real values. .env is gitignored.

# LLM APIs
ANTHROPIC_API_KEY=sk-ant-...
# Models: PRIMARY_MODEL is the Sonnet default; HEAVY_MODEL (Opus) is used by the
# DV2.0 modeler for the hardest reasoning step (ADR-0001). Override only with valid
# current Claude identifiers.
PRIMARY_MODEL=claude-sonnet-4-6
HEAVY_MODEL=claude-opus-4-8

# Optional: tracing / observability
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=vault-agent-dev

# Optional: target platforms for demo
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PRIVATE_KEY_PATH=

# Logging level
LOG_LEVEL=INFO
