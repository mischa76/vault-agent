# Copy to .env and fill in real values. .env is gitignored.

# LLM APIs
ANTHROPIC_API_KEY=sk-ant-...

# Optional: tracing / observability
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=vault-agent-dev

# Optional: target platforms for demo
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PRIVATE_KEY_PATH=

# Logging level
LOG_LEVEL=INFO
